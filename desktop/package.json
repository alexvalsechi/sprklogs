{
  "name": "spark-log-analyzer-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for local Spark ZIP reduction + backend LLM analysis",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node -e \"require('./package.json'); console.log('desktop package ok')\"",
    "pack:win": "electron-builder --win --dir",
    "dist:win": "electron-builder --win nsis --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sparklogs.analyzer.desktop",
    "productName": "Spark Log Analyzer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

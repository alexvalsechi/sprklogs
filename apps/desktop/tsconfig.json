{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": false
  },
  "include": ["main/**/*.ts", "preload/**/*.ts"],
  "exclude": ["node_modules", "dist", "renderer"]
}
